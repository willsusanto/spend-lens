# Public URL for the Next.js app.
# Local development:
NEXT_PUBLIC_URL=http://localhost:3000
# Railway deployment example:
# NEXT_PUBLIC_URL=https://your-app.up.railway.app

# Finance persistence mode.
# Use localStorage to keep data in the current browser only.
# Use database to save finance data through /api/finance-store into PostgreSQL.
# Allowed values: localStorage, database
NEXT_PUBLIC_FINANCE_STORE_MODE=localStorage

# Ollama settings used as server-side defaults.
# These can also be changed from the in-app Settings page.
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1

# PostgreSQL connection string.
# Required only when NEXT_PUBLIC_FINANCE_STORE_MODE=database.
#
# Railway deployment:
# - Add a PostgreSQL service in Railway.
# - In your app service variables, set DATABASE_URL to Railway's PostgreSQL
#   DATABASE_URL variable. Railway's private/internal URL is preferred when the
#   app is deployed in the same Railway project.
#
# Local development against Railway:
# - Use Railway's public PostgreSQL connection URL because localhost cannot use
#   Railway private networking.
# - If the public URL requires TLS, append ?sslmode=require.
#
# Never prefix this with NEXT_PUBLIC_. It must stay server-only.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
