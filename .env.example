# Public URL for the Next.js app.
# Local development:
NEXT_PUBLIC_URL=http://localhost:3000
# Railway deployment example:
# NEXT_PUBLIC_URL=https://your-app.up.railway.app

# Finance persistence mode.
# SpendLens strictly uses database persistence (PostgreSQL) at runtime.
# Allowed values: database
NEXT_PUBLIC_FINANCE_STORE_MODE=database

# Hosted mode settings.
# Set to true to disable CSV uploads, Ollama settings, and local sync badges (for mobile-accessible deployments).
# Allowed values: true, false
NEXT_PUBLIC_HOSTED_MODE=false

# Ollama settings used as server-side defaults.
# These can also be changed from the in-app Settings page.
# The server only allows local/private Ollama endpoints to avoid sending
# transaction descriptions to public or unexpected network targets.
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

# PostgreSQL connection string.
# Required only when NEXT_PUBLIC_FINANCE_STORE_MODE=database.
# URL-encode special characters in the username/password.
#
# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spendlens
#
# Supabase:
# - Create or open a Supabase project.
# - Copy a PostgreSQL connection string from the Supabase database settings.
# - Paste it here as DATABASE_URL. For local development, use a URI that is
#   reachable from your machine.
# - Supabase-hosted connections usually require TLS, so keep or append
#   ?sslmode=require when the copied URI does not already include an SSL mode.
#
# Example Supabase shape:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres?sslmode=require
#
# Railway deployment:
# - Add a PostgreSQL service in Railway.
# - In your app service variables, set DATABASE_URL to Railway's PostgreSQL
#   DATABASE_URL variable. Railway's private/internal URL is preferred when the
#   app is deployed in the same Railway project.
#
# Local development against Railway:
# - Use Railway's public PostgreSQL connection URL because localhost cannot use
#   Railway private networking.
# - If the public URL requires TLS, append ?sslmode=require.
#
# Never prefix this with NEXT_PUBLIC_. It must stay server-only.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
