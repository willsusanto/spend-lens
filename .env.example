NEXT_PUBLIC_URL=http://localhost:3000

# localStorage keeps data in the browser.
# database is reserved for the future DB-backed FinanceStore implementation.
NEXT_PUBLIC_FINANCE_STORE_MODE=localStorage

OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1

# SQLite-style local file example:
DATABASE_URL=file:./data/ledgerlocal.db
# PostgreSQL example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
